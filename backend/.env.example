# Copy to .env and fill in as needed. All keys are OPTIONAL — the app runs fully
# on free, keyless sources (SEC EDGAR + Yahoo Finance). Keys only enable extra
# providers / higher limits (PRD 02).

# SEC requires a descriptive User-Agent with your contact email.
SEC_USER_AGENT="Financial Atlas you@example.com"

# Database: SQLite locally (default); set a Postgres URL on Render (PRD 30).
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/atlas

# Optional provider keys (leave blank to keep those providers disabled).
FMP_API_KEY=
FINNHUB_API_KEY=

LOG_LEVEL=info
ENV=local
